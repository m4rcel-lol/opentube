{
  "name": "@opentube/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "create-admin": "tsx src/scripts/createAdmin.ts",
    "create-reset-token": "tsx src/scripts/createResetToken.ts",
    "seed:demo": "tsx src/scripts/seedDemo.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@opentube/shared": "file:../../packages/shared",
    "@prisma/client": "^5.18.0",
    "argon2": "^0.40.3",
    "bullmq": "^5.12.10",
    "fastify": "^5.8.5",
    "file-type": "^22.0.1",
    "ioredis": "5.10.1",
    "nanoid": "^5.0.7",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/sanitize-html": "^2.11.0",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
