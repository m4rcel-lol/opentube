NODE_ENV=production
OPENTUBE_DOMAIN=localhost

POSTGRES_USER=opentube
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=opentube
DATABASE_URL=postgresql://opentube:change-this-postgres-password@postgres:5432/opentube?schema=public

REDIS_URL=redis://valkey:6379

BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
COOKIE_SECURE=false
SESSION_TTL_DAYS=30
CSRF_COOKIE_NAME=ot_csrf
SESSION_COOKIE_NAME=ot_session
VIEW_HASH_SECRET=change-this-long-random-view-secret

STORAGE_ROOT=/app/storage
MAX_UPLOAD_BYTES=536870912

WORKER_HEALTH_PORT=3002

# Optional first-start admin bootstrap. Leave unset unless you intend to create one.
OPENTUBE_ADMIN_USERNAME=
OPENTUBE_ADMIN_EMAIL=
OPENTUBE_ADMIN_PASSWORD=
